APP_NAME=ink-auth
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ink?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
LOGIN_RATE_LIMIT_WINDOW=5m
LOGIN_RATE_LIMIT_MAX=10
AI_CONFIG_ENCRYPTION_KEY=replace-with-a-32-byte-base64-or-raw-secret
AI_PROVIDER_TIMEOUT=45s
AI_ALLOW_INSECURE_PRIVATE_URL=false
MEMOBIRD_ACCESS_KEY=
MEMOBIRD_BASE_URL=
MEMOBIRD_TIMEOUT=30s
PLUGIN_ROOT=.plugins
PLUGIN_EXEC_TIMEOUT=20s
PLUGIN_INSTALL_TIMEOUT=2m
PLUGIN_UPLOAD_MAX_BYTES=33554432
PLUGIN_OUTPUT_MAX_BYTES=1048576
PLUGIN_FETCH_MAX_ITEMS=100
PLUGIN_FETCH_MAX_BLOCKS_PER_ITEM=80
PLUGIN_FETCH_MAX_TEXT_BYTES=32768
PLUGIN_FETCH_MAX_URL_BYTES=2048
PLUGIN_ENV_ALLOWLIST=
PLUGIN_GIT_ALLOWED_HOSTS=github.com,gitee.com,gitlab.com
SCHEDULER_POLL_INTERVAL=30s
