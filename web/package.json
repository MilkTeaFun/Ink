{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "check": "pnpm lint && pnpm format:check && pnpm test:run && pnpm build",
    "format": "oxfmt -c .oxfmtrc.json .",
    "format:check": "oxfmt -c .oxfmtrc.json --check .",
    "lint": "oxlint -c .oxlintrc.json --deny-warnings src vite.config.ts tailwind.config.ts postcss.config.js",
    "lint:fix": "oxlint -c .oxlintrc.json --fix --deny-warnings src vite.config.ts tailwind.config.ts postcss.config.js",
    "precommit": "lint-staged",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "17.0.7",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "postcss": "^8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "~6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,vue}": [
      "pnpm exec oxlint -c .oxlintrc.json --fix --deny-warnings",
      "pnpm exec oxfmt -c .oxfmtrc.json"
    ],
    "*.{json,jsonc,json5,css,scss,less,html,md,mdx,yaml,yml,toml}": [
      "pnpm exec oxfmt -c .oxfmtrc.json --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "brace-expansion": "2.0.3",
      "js-cookie": "3.0.7",
      "picomatch": "4.0.4",
      "yaml": "2.8.3"
    }
  }
}
